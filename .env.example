# REDTHREAD — environment template. Copy to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real keys.

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL and PUBLISHABLE key are safe to expose to the browser.
# Security is enforced by Row Level Security, not key secrecy.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Legacy anon JWT (optional — some tooling still expects this name)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database password — used by the Supabase CLI for migrations against the
# linked project. Only needed locally / in CI.
SUPABASE_DB_PASSWORD=

# Server-only SECRET key (sb_secret_…). BYPASSES RLS — never expose to client.
# Required for moderation actions and the cron signal-snapshot (Phase 3+).
SUPABASE_SECRET_KEY=

# ── External data APIs (The Wire — Phase 3, all free) ───────────────────────
# NASA: https://api.nasa.gov  (DEMO_KEY works for light use)
NASA_API_KEY=DEMO_KEY
# OpenSky OAuth2 client-credentials (optional; raises rate limits).
# https://opensky-network.org → account → API client
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Magic-link delivery is handled by Supabase Auth → Custom SMTP (paste this key
# as the SMTP password there). This var is for future app-side sends (v2).
RESEND_API_KEY=

# ── Donate ("The Black Budget") — Stripe ────────────────────────────────────
# Pay-what-you-want one-time donations via Stripe Checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# A custom_unit_amount ("customer chooses price") Price — Stripe → Products.
STRIPE_DONATION_PRICE_ID=price_xxx
# Webhook signing secret — Stripe → Developers → Webhooks.
#   Endpoint: https://YOUR-DOMAIN/api/stripe/webhook   (event: checkout.session.completed)
# Grants the Benefactor mark on payment; also needs SUPABASE_SECRET_KEY (above)
# so the webhook can write to the service-role-only `supporters` table.
STRIPE_WEBHOOK_SECRET=whsec_xxx
